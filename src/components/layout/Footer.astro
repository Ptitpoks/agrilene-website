---
const currentYear = new Date().getFullYear();
---

<footer style="background-color: var(--color-brown)" class="text-white/80">
  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Col 1: Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 mb-4" aria-label="AGRILENE accueil">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <circle cx="16" cy="16" r="15" fill="rgba(234,241,229,0.15)" stroke="rgba(121,184,63,0.6)" stroke-width="1.5"/>
            <path d="M16 26 C16 26 16 12 16 8 M16 8 C16 5 13 3 10 3 M16 8 C16 5 19 3 22 3 M16 14 C14 13 11 15 10 17 M16 20 C18 19 21 21 22 23" stroke="#79B83F" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="text-lg font-bold tracking-tight text-white" style="font-family: var(--font-display)">
            AGRI<span style="color: var(--color-green-bright)">LENE</span>
          </span>
        </a>
        <p class="text-sm leading-relaxed text-white/65 max-w-xs">
          Entreprise familiale depuis 1980, AGRILENE accompagne les professionnels du végétal avec des substrats et supports de culture éprouvés.
        </p>
      </div>

      <!-- Col 2: Navigation -->
      <div>
        <h3 class="text-xs font-semibold tracking-widest uppercase text-white/40 mb-4">Navigation</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/solutions" class="hover:text-white transition-colors">Solutions</a></li>
          <li><a href="/produits" class="hover:text-white transition-colors">Produits</a></li>
          <li><a href="/marches/production-vegetale" class="hover:text-white transition-colors">Production végétale</a></li>
          <li><a href="/marches/paysagisme" class="hover:text-white transition-colors">Paysagisme</a></li>
          <li><a href="/marches/collectivites" class="hover:text-white transition-colors">Collectivités</a></li>
        </ul>
      </div>

      <!-- Col 3: Entreprise -->
      <div>
        <h3 class="text-xs font-semibold tracking-widest uppercase text-white/40 mb-4">Entreprise</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/a-propos" class="hover:text-white transition-colors">À propos</a></li>
          <li><a href="/lonoa" class="hover:text-white transition-colors">LONOA</a></li>
          <li><a href="/essais" class="hover:text-white transition-colors">Essais terrain</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Col 4: Contact -->
      <div>
        <h3 class="text-xs font-semibold tracking-widest uppercase text-white/40 mb-4">Contact</h3>
        <address class="not-italic space-y-3 text-sm text-white/65">
          <div>
            <p>Maule, 78580</p>
            <p>Yvelines, Île-de-France, France</p>
          </div>
          <div>
            <a href="tel:+33682077693" class="hover:text-white transition-colors">+33 6 82 07 76 93</a>
          </div>
          <div>
            <a href="mailto:contact@agrilene.fr" class="hover:text-white transition-colors">contact@agrilene.fr</a>
          </div>
        </address>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-white/40">
      <p>© {currentYear} AGRILENE. Tous droits réservés.</p>
      <div class="flex gap-6">
        <a href="/mentions-legales" class="hover:text-white/70 transition-colors">Mentions légales</a>
        <a href="/politique-de-confidentialite" class="hover:text-white/70 transition-colors">Politique de confidentialité</a>
      </div>
    </div>
  </div>
</footer>

---
interface Props {
  ratio?: '16/9' | '4/3' | '1/1' | '3/2' | '3/4';
  alt: string;
  label?: string;
  class?: string;
}

const { ratio = '4/3', alt, label, class: className = '' } = Astro.props;

const paddingMap: Record<string, string> = {
  '16/9': 'pb-[56.25%]',
  '4/3': 'pb-[75%]',
  '1/1': 'pb-[100%]',
  '3/2': 'pb-[66.66%]',
  '3/4': 'pb-[133.33%]',
};

const padding = paddingMap[ratio] ?? 'pb-[75%]';
---

<div
  class={`relative overflow-hidden rounded-2xl bg-cream ${padding} ${className}`}
  role="img"
  aria-label={alt}
>
  <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 p-6">
    <!-- Decorative root/sprout SVG -->
    <svg
      width="48"
      height="48"
      viewBox="0 0 48 48"
      fill="none"
      aria-hidden="true"
      class="opacity-30"
    >
      <path
        d="M24 40 C24 40 24 20 24 12 M24 12 C24 8 20 4 16 4 M24 12 C24 8 28 4 32 4 M24 20 C24 20 18 18 14 22 M24 28 C24 28 30 26 34 30"
        stroke="#3C8A3E"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <circle cx="24" cy="40" r="3" fill="#3C8A3E" opacity="0.4" />
    </svg>
    {label && (
      <p class="text-center text-xs text-muted/60 font-medium">{label}</p>
    )}
    <p class="text-center text-xs text-muted/40 italic">{alt}</p>
  </div>
</div>

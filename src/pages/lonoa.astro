---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import Button from '../components/ui/Button.astro';
import ImagePlaceholder from '../components/ui/ImagePlaceholder.astro';
import BandeauCTA from '../components/sections/BandeauCTA.astro';
import Icon from '../components/ui/Icon.astro';
import { appLinks } from '../config/links';
import { dosageConfig, dosageModes } from '../config/dosage';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Brand',
    name: 'LONOA',
    description: "Marque grand public d'AGRILENE — amendements minéraux pour réguler l'eau dans les substrats des particuliers.",
    url: 'https://www.agrilene.fr/lonoa',
  },
];

const etapes = [
  {
    num: '1',
    titre: 'Vous mélangez',
    texte: 'Incorporez LONOA à votre terreau lors du rempotage ou de la plantation.',
  },
  {
    num: '2',
    titre: 'Le matériau stocke',
    texte: "LONOA agit comme une éponge minérale — il absorbe l'eau lors de l'arrosage et la conserve.",
  },
  {
    num: '3',
    titre: 'La plante puise',
    texte: "La plante prélève l'eau selon ses besoins — vous arrosez moins, et vos plantes tiennent mieux.",
  },
];

const benefices = [
  { texte: "L'eau reste disponible plus longtemps", icon: 'Droplet' as const },
  { texte: "Meilleures conditions racinaires", icon: 'Sprout' as const },
  { texte: "Moins de pression d'entretien", icon: 'CheckCircle' as const },
];

const gamme = [
  { nom: 'LONOA Rempotage', usage: 'Rempotage et culture en pot', benefice: "Régule l'humidité au cœur de la motte" },
  { nom: 'LONOA Semis', usage: 'Semis et jeunes plants', benefice: "Germination homogène, moins de stress" },
  { nom: 'LONOA Gazon', usage: 'Gazon et engazonnement', benefice: "Pelouse plus résiliente, arrosage espacé" },
  { nom: 'LONOA Plantation', usage: 'Plantation en pleine terre', benefice: "Meilleure reprise, moins de pertes" },
];

const calcConfig = dosageModes.map((key) => ({
  key,
  ...dosageConfig[key],
}));
---

<Layout
  title="LONOA — Des plantes qui tiennent, même quand vous n'y pensez pas"
  description="LONOA se mélange à votre terreau pour stocker l'eau et la redonner à vos plantes au bon moment. Moins d'arrosage, des racines plus fortes."
  jsonLd={jsonLd}
>

  <!-- HERO -->
  <section class="relative overflow-hidden bg-paper pt-16 pb-20 md:pt-24 md:pb-28">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <svg class="particle particle-2 absolute top-20 right-[8%] opacity-[0.06]" width="36" height="48" viewBox="0 0 36 48" fill="none">
        <ellipse cx="18" cy="12" rx="12" ry="12" fill="#3E9BC0"/>
        <path d="M18 24 L12 48 M18 24 L24 48" stroke="#3E9BC0" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <svg class="particle particle-1 absolute bottom-20 left-[12%] opacity-[0.05]" width="40" height="40" viewBox="0 0 40 40" fill="none">
        <circle cx="20" cy="20" r="18" fill="#3E9BC0"/>
        <circle cx="14" cy="15" r="3" fill="#FBFAF6"/>
        <circle cx="26" cy="13" r="2" fill="#FBFAF6"/>
        <circle cx="20" cy="27" r="4" fill="#FBFAF6"/>
      </svg>
    </div>

    <div class="container relative">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <div>
          <div class="inline-flex items-center gap-2 mb-4 px-3 py-1.5 rounded-full text-xs font-semibold text-white" style="background-color: var(--color-blue)">
            LONOA — Par AGRILENE
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-ink mb-6 leading-tight" style="font-family: var(--font-display)">
            Des plantes qui tiennent, même quand vous n'y pensez pas
          </h1>
          <p class="text-lg text-muted mb-8 leading-relaxed max-w-xl">
            LONOA se mélange à votre terreau pour stocker l'eau et la redonner à vos plantes au bon moment — moins d'arrosage, des racines plus fortes.
          </p>

          <div class="flex flex-wrap gap-3 mb-10">
            <a href="#gamme" class="inline-flex items-center gap-2 text-sm font-semibold px-6 py-3 rounded-full text-white transition-opacity hover:opacity-90" style="background-color: var(--color-blue)">
              Voir la gamme
            </a>
            <a href="#comment-ca-marche" class="inline-flex items-center gap-2 text-sm font-semibold px-6 py-3 rounded-full border-2 text-ink transition-colors hover:bg-ink hover:text-white" style="border-color: var(--color-ink)">
              Comment ça marche
            </a>
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            {[
              { icon: 'Award' as const, label: "Minéraux de qualité pro" },
              { icon: 'Calendar' as const, label: "40+ ans d'expertise" },
              { icon: 'Globe' as const, label: "Éprouvé en conditions extrêmes" },
            ].map((item) => (
              <div class="flex items-center gap-2 text-sm text-muted">
                <Icon name={item.icon} size={15} style="color: var(--color-blue)" />
                <span>{item.label}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="relative">
          <ImagePlaceholder
            ratio="4/3"
            alt="Pot en coupe avec et sans LONOA — racines vigoureuses et eau bien retenue"
            label="Visuel à venir : pot en coupe sans/avec LONOA"
          />
          <div class="absolute bottom-4 left-4 bg-white/95 backdrop-blur-sm rounded-xl p-4 shadow-lg border border-blue/10 max-w-[190px]">
            <div class="flex items-center gap-2 mb-1">
              <Icon name="Droplet" size={15} style="color: var(--color-blue)" />
              <span class="text-xs font-bold" style="color: var(--color-blue); font-family: var(--font-display)">LONOA</span>
            </div>
            <p class="text-xs text-muted leading-tight">Un sol plus malin. Des racines plus fortes. Moins d'approximation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SANS / AVEC LONOA -->
  <section class="py-20 bg-cream">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <ImagePlaceholder
            ratio="3/2"
            alt="Comparaison plante stressée vs plante vigoureuse avec LONOA"
            label="Visuel comparatif sans/avec LONOA"
          />
        </div>

        <div class="reveal">
          <Eyebrow color="blue" class="mb-4">La différence LONOA</Eyebrow>
          <h2 class="text-3xl font-bold text-ink mb-6" style="font-family: var(--font-display)">
            Sans et avec LONOA
          </h2>
          <div class="space-y-4">
            {benefices.map((b) => (
              <div class="flex gap-4 items-start">
                <div class="shrink-0" aria-hidden="true">
                  <Icon name={b.icon} size={22} style="color: var(--color-blue)" />
                </div>
                <p class="text-ink font-medium">{b.texte}</p>
              </div>
            ))}
          </div>
          <p class="mt-6 text-sm text-muted italic">
            LONOA n'est pas un engrais : c'est un <strong class="text-ink">régulateur d'eau minéral</strong> qui améliore les conditions racinaires.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- COMMENT ÇA MARCHE -->
  <section id="comment-ca-marche" class="py-20 bg-paper">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <Eyebrow color="blue" class="mb-3">Mode d'emploi</Eyebrow>
        <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4" style="font-family: var(--font-display)">
          Comment ça marche
        </h2>
        <p class="text-muted max-w-xl mx-auto">Simple comme un mélange.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {etapes.map((e) => (
          <div class="text-center reveal card-lift bg-sage rounded-2xl p-8">
            <div class="w-12 h-12 rounded-full flex items-center justify-center text-lg font-bold text-white mx-auto mb-4" style="background-color: var(--color-blue)">
              {e.num}
            </div>
            <h3 class="font-bold text-ink mb-2" style="font-family: var(--font-display)">{e.titre}</h3>
            <p class="text-sm text-muted">{e.texte}</p>
          </div>
        ))}
      </div>

      <p class="text-center text-sm text-muted mt-8 italic">
        LONOA n'est pas un engrais, c'est un régulateur d'eau.
      </p>
    </div>
  </section>

  <!-- LA GAMME -->
  <section id="gamme" class="py-20 bg-cream">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <Eyebrow color="blue" class="mb-3">Gamme</Eyebrow>
        <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4" style="font-family: var(--font-display)">
          La gamme LONOA
        </h2>
        <p class="text-muted max-w-xl mx-auto">Un produit adapté à chaque usage.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {gamme.map((s) => (
          <article class="bg-paper rounded-2xl overflow-hidden card-lift reveal">
            <ImagePlaceholder ratio="1/1" alt={`Sac ${s.nom}`} label="Visuel sac à venir" />
            <div class="p-5">
              <h3 class="font-bold text-ink mb-1" style="font-family: var(--font-display)">{s.nom}</h3>
              <p class="text-xs text-muted mb-2">{s.usage}</p>
              <p class="text-sm font-medium" style="color: var(--color-blue)">{s.benefice}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- APP MANA -->
  <section class="py-20 bg-paper">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <Eyebrow color="blue" class="mb-4">Application mobile</Eyebrow>
          <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4" style="font-family: var(--font-display)">
            Mana — l'appli qui veille sur vos plantes
          </h2>
          <p class="text-muted mb-6 leading-relaxed">
            Prenez votre plante en photo : <strong class="text-ink">Mana</strong> la reconnaît, établit un <strong class="text-ink">diagnostic de santé</strong> et propose des <strong class="text-ink">solutions à court terme</strong> et des <strong class="text-ink">conseils d'entretien</strong> — avec le bon produit LONOA si besoin.
          </p>

          <div class="inline-flex items-center gap-3 bg-blue/5 border border-blue/20 rounded-xl px-5 py-4">
            <Icon name="FlaskConical" size={20} style="color: var(--color-blue)" />
            <p class="text-sm font-medium" style="color: var(--color-blue)">
              {appLinks.manaStatus}
            </p>
          </div>

          {(appLinks.manaAppStore || appLinks.manaGooglePlay) && (
            <div class="flex flex-wrap gap-3 mt-4">
              {appLinks.manaAppStore && (
                <a
                  href={appLinks.manaAppStore}
                  class="inline-flex items-center gap-2 bg-ink text-white text-sm font-semibold px-5 py-3 rounded-xl hover:opacity-90 transition-opacity"
                >
                  App Store
                </a>
              )}
              {appLinks.manaGooglePlay && (
                <a
                  href={appLinks.manaGooglePlay}
                  class="inline-flex items-center gap-2 bg-ink text-white text-sm font-semibold px-5 py-3 rounded-xl hover:opacity-90 transition-opacity"
                >
                  Google Play
                </a>
              )}
            </div>
          )}
        </div>

        <div class="reveal">
          <ImagePlaceholder ratio="3/4" alt="Captures d'écran de l'application Mana — diagnostic de plante par photo" label="Captures Mana à venir" />
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATEUR 4 MODES -->
  <section class="py-20 bg-sage">
    <div class="container max-w-2xl">
      <div class="text-center mb-8 reveal">
        <Eyebrow color="blue" class="mb-3">Dosage</Eyebrow>
        <h2 class="text-3xl font-bold text-ink mb-3" style="font-family: var(--font-display)">
          Calculateur de dosage
        </h2>
        <p class="text-muted">Estimez la quantité de LONOA selon votre usage.</p>
      </div>

      <div class="bg-paper rounded-2xl p-6 reveal" id="calc-lonoa">
        <!-- Mode selector -->
        <div class="mb-5">
          <label class="block text-sm font-medium text-ink mb-2">Usage</label>
          <div class="grid grid-cols-2 gap-2" role="radiogroup" aria-label="Mode de dosage">
            {calcConfig.map((m, i) => (
              <label class="cursor-pointer">
                <input
                  type="radio"
                  name="calc-mode"
                  value={m.key}
                  class="sr-only"
                  checked={i === 0}
                  data-label={m.label}
                  data-input-label={m.inputLabel}
                  data-unit={m.inputUnit}
                  data-default-pct={m.defaultPct}
                  data-depth-cm={m.depthCm ?? ''}
                  data-bag-volume={m.bagVolume}
                  data-show-bags={m.showBags ? '1' : '0'}
                  data-hint={m.hint ?? ''}
                  data-options={JSON.stringify(m.options)}
                />
                <span class="mode-btn block text-center text-xs font-semibold px-3 py-2.5 rounded-xl border-2 transition-all hover:border-blue/50" style="border-color: var(--color-ink); color: var(--color-ink);">
                  {m.label}
                </span>
              </label>
            ))}
          </div>
        </div>

        <!-- Inputs -->
        <div class="grid sm:grid-cols-2 gap-4 mb-5">
          <div>
            <label for="calc-input" id="calc-input-label" class="block text-sm font-medium text-ink mb-1.5">
              {calcConfig[0].inputLabel}
            </label>
            <div class="flex items-center gap-2">
              <input
                type="number"
                id="calc-input"
                min="0.1"
                max="10000"
                value="10"
                step="0.5"
                class="w-full border border-ink/20 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2"
                style="--tw-ring-color: var(--color-blue)"
              />
              <span id="calc-unit" class="text-sm text-muted shrink-0 min-w-[24px]">L</span>
            </div>
          </div>
          <div>
            <label for="calc-taux" class="block text-sm font-medium text-ink mb-1.5">Taux de mélange</label>
            <select
              id="calc-taux"
              class="w-full border border-ink/20 rounded-xl px-4 py-2.5 text-sm bg-white focus:outline-none focus:ring-2"
              style="--tw-ring-color: var(--color-blue)"
            >
              {calcConfig[0].options.map((o) => (
                <option value={o.pct} selected={o.pct === calcConfig[0].defaultPct}>{o.label}</option>
              ))}
            </select>
          </div>
        </div>

        <div class="bg-blue/10 rounded-xl p-5 text-center">
          <p class="text-sm text-muted mb-1">Quantité de LONOA conseillée</p>
          <p id="calc-result" class="text-3xl font-extrabold" style="font-family: var(--font-display); color: var(--color-blue)">2 L</p>
          <p id="calc-detail" class="text-xs text-muted mt-1"></p>
          <p id="calc-bags" class="text-xs text-muted mt-0.5 hidden"></p>
        </div>

        <p id="calc-hint" class="text-xs text-muted mt-3 italic hidden"></p>
      </div>
    </div>
  </section>

  <!-- OÙ TROUVER LONOA -->
  <section class="py-20 bg-paper">
    <div class="container text-center reveal">
      <Eyebrow color="blue" class="mb-4">Distribution</Eyebrow>
      <h2 class="text-3xl font-bold text-ink mb-4" style="font-family: var(--font-display)">Où trouver LONOA</h2>
      <p class="text-muted max-w-xl mx-auto">
        Bientôt disponible en ligne (Amazon et autres plateformes). Réseau de revendeurs en cours de développement.
      </p>
    </div>
  </section>

  <!-- BLOC DISTRIBUTEURS -->
  <section class="py-20 bg-cream">
    <div class="container">
      <div class="max-w-3xl mx-auto bg-paper rounded-2xl p-8 md:p-10 reveal">
        <Eyebrow color="orange" class="mb-4">Pour les professionnels</Eyebrow>
        <h2 class="text-2xl md:text-3xl font-bold text-ink mb-4" style="font-family: var(--font-display)">
          Vous êtes une enseigne ou un distributeur ?
        </h2>
        <p class="text-muted mb-6 leading-relaxed">
          LONOA est un produit différenciant avec une forte demande grand public. Nous accompagnons nos distributeurs avec du matériel de communication, une application mobile incluse (Mana) et un support technique dédié.
        </p>
        <ul class="space-y-2 mb-8 text-sm text-ink">
          {['Produit différenciant sur le marché', 'Application Mana incluse pour vos clients', 'Accompagnement commercial et technique', 'Formation et matériel de vente fournis'].map((item) => (
            <li class="flex gap-2">
              <span class="font-bold" style="color: var(--color-green)">✓</span>
              {item}
            </li>
          ))}
        </ul>
        <Button href="/contact?type=distribution" variant="primary" arrow>Devenir distributeur</Button>
      </div>
    </div>
  </section>

  <!-- BANDEAU CTA -->
  <BandeauCTA
    titre="Des questions sur LONOA ?"
    sousTitre="Notre équipe est disponible pour vous renseigner sur les produits, les dosages et les points de vente."
    ctaLabel="Nous contacter"
    ctaHref="/contact"
    ctaVariant="orange"
    bg="brown"
  />

</Layout>

<script>
  interface ModeOption { pct: number; label: string; }

  const calcInput = document.getElementById('calc-input') as HTMLInputElement | null;
  const calcTaux = document.getElementById('calc-taux') as HTMLSelectElement | null;
  const calcResult = document.getElementById('calc-result');
  const calcDetail = document.getElementById('calc-detail');
  const calcBags = document.getElementById('calc-bags');
  const calcHint = document.getElementById('calc-hint');
  const calcInputLabel = document.getElementById('calc-input-label');
  const calcUnit = document.getElementById('calc-unit');

  const modeBtns = document.querySelectorAll<HTMLElement>('.mode-btn');
  const modeRadios = document.querySelectorAll<HTMLInputElement>('input[name="calc-mode"]');

  function formatL(v: number): string {
    return v < 1 ? `${(v * 1000).toFixed(0)} mL` : `${v.toFixed(1).replace('.0', '')} L`;
  }

  function updateCalc() {
    const activeRadio = document.querySelector<HTMLInputElement>('input[name="calc-mode"]:checked');
    if (!activeRadio || !calcInput || !calcTaux || !calcResult) return;

    const inputVal = parseFloat(calcInput.value) || 0;
    const taux = parseFloat(calcTaux.value) || 20;
    const depthCm = parseFloat(activeRadio.dataset.depthCm || '0');
    const bagVolume = parseFloat(activeRadio.dataset.bagVolume || '80');
    const showBags = activeRadio.dataset.showBags === '1';
    const hint = activeRadio.dataset.hint || '';

    let volLonoa: number;
    let detailText: string;

    if (depthCm > 0) {
      // Surface mode (gazon): volume = surface × depth × taux
      const depthM = depthCm / 100;
      const totalVol = inputVal * depthM * 1000; // in L
      volLonoa = Math.round((totalVol * (taux / 100)) * 10) / 10;
      detailText = `${taux} % × ${inputVal} m² × ${depthCm} cm de profondeur`;
    } else {
      // Volume mode: volume × taux
      volLonoa = Math.round(inputVal * (taux / 100) * 10) / 10;
      detailText = `${taux} % du volume de ${inputVal} ${activeRadio.dataset.unit}`;
    }

    calcResult.textContent = formatL(volLonoa);
    if (calcDetail) calcDetail.textContent = detailText;

    if (calcBags) {
      if (showBags && volLonoa > 0) {
        const bags = Math.ceil(volLonoa / bagVolume);
        calcBags.textContent = `≈ ${bags} sac${bags > 1 ? 's' : ''} de ${bagVolume} L`;
        calcBags.classList.remove('hidden');
      } else {
        calcBags.classList.add('hidden');
      }
    }

    if (calcHint) {
      if (hint) {
        calcHint.textContent = hint;
        calcHint.classList.remove('hidden');
      } else {
        calcHint.classList.add('hidden');
      }
    }
  }

  function activateMode(radio: HTMLInputElement) {
    // Update labels
    if (calcInputLabel) calcInputLabel.textContent = radio.dataset.inputLabel ?? '';
    if (calcUnit) calcUnit.textContent = radio.dataset.unit ?? '';

    // Update options in select
    if (calcTaux) {
      try {
        const options: ModeOption[] = JSON.parse(radio.dataset.options || '[]');
        const defaultPct = parseInt(radio.dataset.defaultPct || '20');
        calcTaux.innerHTML = options
          .map((o) => `<option value="${o.pct}"${o.pct === defaultPct ? ' selected' : ''}>${o.label}</option>`)
          .join('');
      } catch {}
    }

    // Update mode button styles
    modeBtns.forEach((btn) => {
      btn.style.borderColor = 'var(--color-ink)';
      btn.style.color = 'var(--color-ink)';
      btn.style.backgroundColor = '';
    });
    const activeBtn = radio.nextElementSibling as HTMLElement | null;
    if (activeBtn) {
      activeBtn.style.borderColor = 'var(--color-blue)';
      activeBtn.style.color = 'var(--color-blue)';
      activeBtn.style.backgroundColor = 'var(--color-blue)';
      activeBtn.style.color = 'white';
    }

    updateCalc();
  }

  modeRadios.forEach((radio) => {
    radio.addEventListener('change', () => activateMode(radio));
  });

  calcInput?.addEventListener('input', updateCalc);
  calcTaux?.addEventListener('change', updateCalc);

  // Init with first mode
  const firstRadio = document.querySelector<HTMLInputElement>('input[name="calc-mode"]');
  if (firstRadio) activateMode(firstRadio);
</script>

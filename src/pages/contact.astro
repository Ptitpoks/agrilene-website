---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import Icon from '../components/ui/Icon.astro';
import { contactLinks } from '../config/links';
---

<Layout
  title="Contact — Demande commerciale, technique ou distribution | AGRILENE"
  description="Contactez l'équipe AGRILENE pour une demande commerciale, une question technique ou une demande de distribution. Maule (78580), +33 6 82 07 76 93, contact@agrilene.fr."
>

  <!-- HERO -->
  <section class="bg-paper py-16 md:py-20">
    <div class="container max-w-5xl">
      <Eyebrow color="green" class="mb-4">Contact</Eyebrow>
      <h1 class="text-4xl md:text-5xl font-extrabold text-ink mb-4" style="font-family: var(--font-display)">
        Contactez-nous
      </h1>
      <p class="text-lg text-muted max-w-xl">
        Une question technique, une demande commerciale ou un projet de distribution ? Notre équipe est à votre écoute.
      </p>
    </div>
  </section>

  <!-- CONTENU -->
  <section class="pb-24 bg-paper">
    <div class="container max-w-5xl">
      <div class="grid lg:grid-cols-5 gap-12">

        <!-- Coordonnées -->
        <aside class="lg:col-span-2">
          <h2 class="text-xl font-bold text-ink mb-6" style="font-family: var(--font-display)">Nos coordonnées</h2>

          <address class="not-italic space-y-6">
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-xl bg-sage flex items-center justify-center shrink-0" aria-hidden="true">
                <Icon name="MapPin" size={18} style="color: var(--color-green)" />
              </div>
              <div>
                <div class="font-semibold text-ink text-sm mb-0.5">Adresse</div>
                <p class="text-sm text-muted">
                  Maule, 78580<br/>
                  Yvelines, Île-de-France<br/>
                  France
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-xl bg-sage flex items-center justify-center shrink-0" aria-hidden="true">
                <Icon name="Phone" size={18} style="color: var(--color-green)" />
              </div>
              <div>
                <div class="font-semibold text-ink text-sm mb-0.5">Téléphone</div>
                <a href={`tel:${contactLinks.phone}`} class="text-sm text-muted hover:text-green transition-colors">{contactLinks.phoneDisplay}</a>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-xl bg-sage flex items-center justify-center shrink-0" aria-hidden="true">
                <Icon name="Mail" size={18} style="color: var(--color-green)" />
              </div>
              <div>
                <div class="font-semibold text-ink text-sm mb-0.5">Email</div>
                <a href={`mailto:${contactLinks.emailPublic}`} class="text-sm text-muted hover:text-green transition-colors">{contactLinks.emailPublic}</a>
              </div>
            </div>
          </address>

          <div class="mt-8 p-5 bg-cream rounded-xl">
            <div class="flex items-center gap-2 font-semibold text-ink text-sm mb-2">
              <Icon name="Clock" size={15} style="color: var(--color-green)" />
              Horaires
            </div>
            <p class="text-sm text-muted">Du lundi au vendredi</p>
            <p class="text-sm text-ink font-medium">8h30–12h00 / 14h00–17h30</p>
          </div>
        </aside>

        <!-- Formulaire -->
        <div class="lg:col-span-3">
          <h2 class="text-xl font-bold text-ink mb-6" style="font-family: var(--font-display)">Envoyez-nous un message</h2>

          <form
            id="contact-form"
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-5"
            novalidate
          >
            <input type="hidden" name="access_key" value="VOTRE-CLE-WEB3FORMS" />
            <input type="hidden" name="subject" value="Nouveau message depuis agrilene.fr" />
            <input type="hidden" name="from_name" value="Site AGRILENE" />
            <input type="hidden" name="redirect" value="false" />
            <!-- Destinataire interne — non affiché publiquement -->
            <input type="hidden" name="to" value={contactLinks.emailInternal} />
            <!-- Honeypot anti-spam -->
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" aria-hidden="true" />

            <!-- Type de demande -->
            <fieldset>
              <legend class="text-sm font-semibold text-ink mb-3">Type de demande</legend>
              <div class="flex flex-wrap gap-3">
                {['Information commerciale', 'Information technique', 'Distribution'].map((type) => (
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="type_demande"
                      value={type}
                      class="accent-green w-4 h-4"
                    />
                    <span class="text-sm text-ink">{type}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <!-- Champs -->
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="entreprise" class="block text-sm font-medium text-ink mb-1.5">Entreprise</label>
                <input
                  type="text"
                  id="entreprise"
                  name="entreprise"
                  placeholder="Nom de votre entreprise"
                  class="w-full border border-ink/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green/30 focus:border-green bg-white"
                />
              </div>
              <div>
                <label for="nom" class="block text-sm font-medium text-ink mb-1.5">Nom et prénom <span class="text-orange">*</span></label>
                <input
                  type="text"
                  id="nom"
                  name="nom"
                  required
                  placeholder="Votre nom"
                  class="w-full border border-ink/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green/30 focus:border-green bg-white"
                />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="email" class="block text-sm font-medium text-ink mb-1.5">Email <span class="text-orange">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="votre@email.fr"
                  class="w-full border border-ink/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green/30 focus:border-green bg-white"
                />
              </div>
              <div>
                <label for="telephone" class="block text-sm font-medium text-ink mb-1.5">Téléphone</label>
                <input
                  type="tel"
                  id="telephone"
                  name="telephone"
                  placeholder="+33 6 xx xx xx xx"
                  class="w-full border border-ink/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green/30 focus:border-green bg-white"
                />
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-ink mb-1.5">Message <span class="text-orange">*</span></label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Décrivez votre projet ou votre question..."
                class="w-full border border-ink/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green/30 focus:border-green bg-white resize-y"
              ></textarea>
            </div>

            <!-- RGPD -->
            <div>
              <label class="flex gap-3 cursor-pointer items-start">
                <input
                  type="checkbox"
                  name="rgpd"
                  required
                  class="mt-0.5 accent-green w-4 h-4 shrink-0"
                />
                <span class="text-xs text-muted">
                  J'accepte que mes données soient utilisées pour traiter ma demande, conformément à la
                  <a href="/politique-de-confidentialite" class="underline hover:text-ink transition-colors">politique de confidentialité</a>
                  d'AGRILENE.
                </span>
              </label>
            </div>

            <!-- Submit -->
            <div>
              <button
                type="submit"
                class="inline-flex items-center gap-2 bg-green text-white text-sm font-semibold px-8 py-3.5 rounded-full hover:bg-green-dark transition-colors disabled:opacity-50"
              >
                <span id="btn-label">Envoyer le message</span>
                <span id="btn-spinner" class="hidden">
                  <svg class="animate-spin w-4 h-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.3"/>
                    <path d="M12 2a10 10 0 010 20" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                  </svg>
                </span>
              </button>
            </div>

            <!-- Messages état -->
            <div id="form-success" class="hidden p-4 bg-sage rounded-xl text-sm text-green-dark font-medium" role="status">
              Message envoyé avec succès — nous vous répondrons dans les plus brefs délais.
            </div>
            <div id="form-error" class="hidden p-4 bg-orange/10 rounded-xl text-sm text-orange font-medium" role="alert">
              Une erreur est survenue. Veuillez réessayer ou nous contacter directement à <a href={`mailto:${contactLinks.emailPublic}`} class="underline">{contactLinks.emailPublic}</a>.
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successEl = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');
  const btnLabel = document.getElementById('btn-label');
  const btnSpinner = document.getElementById('btn-spinner');
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  // Pre-select type from URL param
  const urlParams = new URLSearchParams(window.location.search);
  const typeParam = urlParams.get('type');
  if (typeParam) {
    const radioMap: Record<string, string> = {
      distribution: 'Distribution',
      technique: 'Information technique',
      commercial: 'Information commerciale',
    };
    const labelVal = radioMap[typeParam.toLowerCase()];
    if (labelVal) {
      const radio = form?.querySelector(`input[value="${labelVal}"]`) as HTMLInputElement | null;
      if (radio) radio.checked = true;
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    const required = form.querySelectorAll('[required]');
    let valid = true;
    required.forEach((el) => {
      const input = el as HTMLInputElement | HTMLTextAreaElement;
      if (input.type === 'checkbox' && !input.checked) valid = false;
      else if (input.value.trim() === '') valid = false;
    });
    if (!valid) {
      form.reportValidity();
      return;
    }

    if (submitBtn) submitBtn.disabled = true;
    btnLabel?.classList.add('hidden');
    btnSpinner?.classList.remove('hidden');

    try {
      const data = new FormData(form);
      const res = await fetch(form.action, { method: 'POST', body: data });
      const json = await res.json();

      btnLabel?.classList.remove('hidden');
      btnSpinner?.classList.add('hidden');
      if (submitBtn) submitBtn.disabled = false;

      if (json.success) {
        form.reset();
        successEl?.classList.remove('hidden');
        errorEl?.classList.add('hidden');
        successEl?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        errorEl?.classList.remove('hidden');
        successEl?.classList.add('hidden');
      }
    } catch {
      btnLabel?.classList.remove('hidden');
      btnSpinner?.classList.add('hidden');
      if (submitBtn) submitBtn.disabled = false;
      errorEl?.classList.remove('hidden');
      successEl?.classList.add('hidden');
    }
  });
</script>

---
import Layout from '../../../layouts/Layout.astro';
import Eyebrow from '../../../components/ui/Eyebrow.astro';
import Button from '../../../components/ui/Button.astro';
import Tag from '../../../components/ui/Tag.astro';
import ImagePlaceholder from '../../../components/ui/ImagePlaceholder.astro';
import BandeauCTA from '../../../components/sections/BandeauCTA.astro';
import Icon from '../../../components/ui/Icon.astro';

const challenges = [
  { iconName: 'Droplet', title: 'Water savings', desc: 'Reduce consumption and irrigation costs' },
  { iconName: 'Sprout', title: 'Durability', desc: 'Climate-resilient plantings facing climate change' },
  { iconName: 'Coins', title: 'Cost control', desc: 'Limit replacements and maintenance' },
  { iconName: 'TreeDeciduous', title: 'Quality of life', desc: 'Attractive, functional green spaces' },
];

const useCases = [
  { title: 'Urban tree pits', desc: 'Technical substrates for root development in constrained environments', products: ['Perlite', 'Vermiculite', 'Florilène'] },
  { title: 'Public green spaces', desc: 'Soil improvement for durable, water-efficient plantings', products: ['Perlite', 'Vermiculite', 'Florilène', 'Miscanthus'] },
  { title: 'Lawns, greens & large areas', desc: 'Water retention for turf, golf greens and large planted surfaces', products: ['Floriroll'] },
  { title: 'Mulching & soil protection', desc: 'Ground cover to limit evaporation and maintenance', products: ['Miscanthus'] },
];

const benefits = [
  'Significant reduction in water consumption', 'Better tree survival in urban environments',
  'Lower maintenance costs', 'Green spaces more resilient to heat waves',
  'Contribution to environmental objectives', 'Positive image with residents',
];

const produitHref: Record<string, string> = {
  'Perlite': '/en/produits#perlite', 'Vermiculite': '/en/produits#vermiculite',
  'Florilène': '/en/produits#florilene', 'Floricubes': '/en/produits#floricubes',
  'Floriroll': '/en/produits#floriroll', 'Miscanthus': '/en/produits#miscanthus',
};
---

<Layout
  title="Local authorities — Solutions for sustainable public green spaces | AGRILENE"
  description="Floriroll, Florilène, perlite, miscanthus: proven solutions to sustainably green public spaces and reduce maintenance costs."
>

  <section class="relative bg-ink text-white py-24 md:py-32 overflow-hidden">
    <div class="container relative">
      <Eyebrow color="orange" class="mb-4">Market</Eyebrow>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight" style="font-family: var(--font-display)">Local authorities</h1>
      <p class="text-lg text-white/75 max-w-2xl">Solutions to sustainably green public spaces. Save water, reduce maintenance and ensure the longevity of your plantings.</p>
    </div>
  </section>

  <section class="py-20 bg-paper">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4" style="font-family: var(--font-display)">Your management challenges</h2>
        <p class="text-muted max-w-2xl mx-auto">Local authorities face budgetary, environmental and climate constraints that call for effective, long-lasting solutions.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {challenges.map((e) => (
          <div class="bg-sage rounded-2xl p-6 reveal card-lift">
            <div class="mb-3" aria-hidden="true"><Icon name={e.iconName as any} size={28} style="color: var(--color-green)" /></div>
            <h3 class="font-bold text-ink mb-2" style="font-family: var(--font-display)">{e.title}</h3>
            <p class="text-sm text-muted">{e.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-cream">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4" style="font-family: var(--font-display)">Proven solutions for public spaces</h2>
        <p class="text-muted max-w-2xl mx-auto">Tried and tested solutions for public spaces and urban landscaping.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-5">
        {useCases.map((c) => (
          <article class="bg-paper rounded-2xl p-6 reveal card-lift">
            <h3 class="font-bold text-ink mb-2" style="font-family: var(--font-display)">{c.title}</h3>
            <p class="text-sm text-muted mb-4">{c.desc}</p>
            <div class="flex flex-wrap gap-2">{c.products.map((p) => <Tag href={produitHref[p] ?? '/en/produits'} color="orange">{p}</Tag>)}</div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-paper">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <h2 class="text-3xl md:text-4xl font-bold text-ink mb-8" style="font-family: var(--font-display)">Benefits for your authority</h2>
          <div class="grid sm:grid-cols-2 gap-3">
            {benefits.map((b) => (
              <div class="flex gap-3 text-sm text-ink items-start">
                <span class="shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-xs font-bold text-white mt-0.5" style="background-color: var(--color-green)">✓</span>
                {b}
              </div>
            ))}
          </div>
          <div class="mt-8"><Button href="/en/produits" variant="primary" arrow>See our products</Button></div>
        </div>
        <div class="reveal"><ImagePlaceholder ratio="4/3" alt="Public green spaces — local authority AGRILENE solutions" label="Coming soon" /></div>
      </div>
    </div>
  </section>

  <BandeauCTA titre="A public green space project?" sousTitre="Our team supports you and shares technical studies relevant to your application." ctaLabel="Contact us" ctaHref="/en/contact" ctaVariant="orange" />
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import Icon from '../../components/ui/Icon.astro';
import { contactLinks } from '../../config/links';
---

<Layout
  title="Contact — Reach our team | AGRILENE"
  description="Contact AGRILENE for any commercial, technical or distribution inquiry. Phone, email, contact form."
  noindex={false}
>

  <section class="bg-paper py-16 md:py-24">
    <div class="container">
      <div class="max-w-3xl">
        <Eyebrow color="green" class="mb-4">Contact</Eyebrow>
        <h1 class="text-4xl md:text-5xl font-extrabold text-ink mb-6" style="font-family: var(--font-display)">
          Reach our team
        </h1>
        <p class="text-lg text-muted max-w-2xl">
          A quote request, a technical question, a distribution inquiry? Fill in the form below or reach us directly — we respond within 24–48 business hours.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-cream">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-14">

        <!-- CONTACT INFO -->
        <div>
          <h2 class="text-2xl font-bold text-ink mb-8" style="font-family: var(--font-display)">Contact details</h2>
          <div class="space-y-6">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background-color: var(--color-sage)">
                <Icon name="Mail" size={18} style="color: var(--color-green)" />
              </div>
              <div>
                <div class="font-semibold text-ink mb-1">Email</div>
                <a href={`mailto:${contactLinks.emailPublic}`} class="text-muted hover:text-green transition-colors">{contactLinks.emailPublic}</a>
              </div>
            </div>

            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background-color: var(--color-sage)">
                <Icon name="Phone" size={18} style="color: var(--color-green)" />
              </div>
              <div>
                <div class="font-semibold text-ink mb-1">Phone</div>
                <a href={`tel:${contactLinks.phone}`} class="text-muted hover:text-green transition-colors">{contactLinks.phoneDisplay}</a>
              </div>
            </div>

            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background-color: var(--color-sage)">
                <Icon name="MapPin" size={18} style="color: var(--color-green)" />
              </div>
              <div>
                <div class="font-semibold text-ink mb-1">Location</div>
                <p class="text-muted">Maule, 78580<br/>Île-de-France, France</p>
              </div>
            </div>

            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background-color: var(--color-sage)">
                <Icon name="Clock" size={18} style="color: var(--color-green)" />
              </div>
              <div>
                <div class="font-semibold text-ink mb-1">Business hours</div>
                <p class="text-muted">Monday–Friday: 9:00–18:00<br/>Saturday–Sunday: closed</p>
              </div>
            </div>
          </div>

          <div class="mt-10 bg-sage rounded-2xl p-6">
            <h3 class="font-bold text-ink mb-3" style="font-family: var(--font-display)">We can help you with:</h3>
            <ul class="space-y-2">
              {[
                'Commercial information and quotes',
                'Technical advice on product choice',
                'Distribution and partnership inquiries',
                'Technical data sheets (TDS/SDS)',
                'Custom professional quantities',
              ].map((item) => (
                <li class="flex gap-2 text-sm text-muted">
                  <span class="shrink-0 font-bold mt-0.5" style="color: var(--color-green)">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- CONTACT FORM -->
        <div>
          <h2 class="text-2xl font-bold text-ink mb-8" style="font-family: var(--font-display)">Send us a message</h2>
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-5"
          >
            <input type="hidden" name="access_key" value="VOTRE-CLE-WEB3FORMS" />
            <input type="hidden" name="to" value={contactLinks.emailInternal} />
            <input type="hidden" name="subject" value="New contact request — AGRILENE website (EN)" />
            <input type="hidden" name="from_name" value="AGRILENE Website (EN)" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="prenom-en" class="block text-sm font-medium text-ink mb-2">First name *</label>
                <input
                  type="text" id="prenom-en" name="prenom" required
                  class="w-full rounded-xl border px-4 py-3 text-sm text-ink bg-white transition-colors focus:outline-none focus:ring-2"
                  style="border-color: var(--color-border); focus:ring-color: var(--color-green)"
                  placeholder="Your first name"
                />
              </div>
              <div>
                <label for="nom-en" class="block text-sm font-medium text-ink mb-2">Last name *</label>
                <input
                  type="text" id="nom-en" name="nom" required
                  class="w-full rounded-xl border px-4 py-3 text-sm text-ink bg-white transition-colors focus:outline-none focus:ring-2"
                  style="border-color: var(--color-border)"
                  placeholder="Your last name"
                />
              </div>
            </div>

            <div>
              <label for="email-en" class="block text-sm font-medium text-ink mb-2">Email *</label>
              <input
                type="email" id="email-en" name="email" required
                class="w-full rounded-xl border px-4 py-3 text-sm text-ink bg-white focus:outline-none focus:ring-2"
                style="border-color: var(--color-border)"
                placeholder="your@email.com"
              />
            </div>

            <div>
              <label for="telephone-en" class="block text-sm font-medium text-ink mb-2">Phone</label>
              <input
                type="tel" id="telephone-en" name="telephone"
                class="w-full rounded-xl border px-4 py-3 text-sm text-ink bg-white focus:outline-none focus:ring-2"
                style="border-color: var(--color-border)"
                placeholder="+44 7700 900000"
              />
            </div>

            <div>
              <label for="entreprise-en" class="block text-sm font-medium text-ink mb-2">Company / Organisation</label>
              <input
                type="text" id="entreprise-en" name="entreprise"
                class="w-full rounded-xl border px-4 py-3 text-sm text-ink bg-white focus:outline-none focus:ring-2"
                style="border-color: var(--color-border)"
                placeholder="Your company (optional)"
              />
            </div>

            <div>
              <label for="type-en" class="block text-sm font-medium text-ink mb-2">Enquiry type *</label>
              <select
                id="type-en" name="type" required
                class="w-full rounded-xl border px-4 py-3 text-sm text-ink bg-white focus:outline-none focus:ring-2 cursor-pointer"
                style="border-color: var(--color-border)"
              >
                <option value="">Select a type</option>
                <option value="Commercial inquiry">Commercial inquiry</option>
                <option value="Technical question">Technical question</option>
                <option value="Distribution / Reseller">Distribution / Reseller</option>
                <option value="Field trial">Field trial</option>
                <option value="Press / Partnership">Press / Partnership</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div>
              <label for="message-en" class="block text-sm font-medium text-ink mb-2">Message *</label>
              <textarea
                id="message-en" name="message" required rows={5}
                class="w-full rounded-xl border px-4 py-3 text-sm text-ink bg-white focus:outline-none focus:ring-2 resize-none"
                style="border-color: var(--color-border)"
                placeholder="Tell us about your project, your needs, the products or quantities you're interested in..."
              ></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input type="checkbox" id="rgpd-en" name="rgpd" required class="mt-1 w-4 h-4 rounded shrink-0" style="accent-color: var(--color-green)" />
              <label for="rgpd-en" class="text-sm text-muted">
                I agree to the processing of my personal data by AGRILENE to respond to my request, in accordance with the
                <a href="/en/politique-de-confidentialite" class="text-green hover:underline">privacy policy</a>.
              </label>
            </div>

            <button
              type="submit"
              class="w-full py-4 px-8 rounded-xl font-semibold text-white transition-opacity hover:opacity-90 focus:outline-none focus:ring-2"
              style="background-color: var(--color-green)"
            >
              Send message
            </button>

            <p class="text-xs text-muted text-center">We typically respond within 24–48 business hours.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

</Layout>

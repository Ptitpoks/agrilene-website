---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Legal notices | AGRILENE"
  description="Legal notices for AGRILENE — company details, publication director, hosting provider."
  noindex={true}
>

  <section class="bg-paper py-16 md:py-20">
    <div class="container max-w-3xl">
      <h1 class="text-4xl font-extrabold text-ink mb-10" style="font-family: var(--font-display)">Legal notices</h1>

      <div class="space-y-8 text-muted text-sm leading-relaxed">

        <div>
          <h2 class="text-xl font-bold text-ink mb-3" style="font-family: var(--font-display)">Publisher</h2>
          <p>
            <strong class="text-ink">AGRILENE</strong> — Société à Responsabilité Limitée (SARL)<br/>
            Share capital: [capital social] €<br/>
            Registered address: 42 B Avenue Pasteur, 78580 Maule, France<br/>
            SIREN: 320 464 514<br/>
            SIRET: 320 464 514 00027<br/>
            RCS: Versailles<br/>
            APE code: 46.69B<br/>
            VAT number: FR73 320 464 514
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-ink mb-3" style="font-family: var(--font-display)">Publication director</h2>
          <p>Théo KARM — Managing Director</p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-ink mb-3" style="font-family: var(--font-display)">Contact</h2>
          <p>
            Email: <a href="mailto:contact@agrilene.fr" class="text-green hover:underline">contact@agrilene.fr</a><br/>
            Phone: <a href="tel:+33682077693" class="text-green hover:underline">+33 6 82 07 76 93</a>
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-ink mb-3" style="font-family: var(--font-display)">Hosting</h2>
          <p>
            This website is hosted by <strong class="text-ink">Cloudflare, Inc.</strong><br/>
            101 Townsend St., San Francisco, CA 94107, USA<br/>
            <a href="https://www.cloudflare.com" rel="noopener noreferrer" target="_blank" class="text-green hover:underline">cloudflare.com</a>
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-ink mb-3" style="font-family: var(--font-display)">Intellectual property</h2>
          <p>All content on this site (texts, images, logos, videos) is the exclusive property of AGRILENE or its partners and is protected by French and international intellectual property law. Any reproduction, even partial, is prohibited without prior written authorisation.</p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-ink mb-3" style="font-family: var(--font-display)">Disclaimer</h2>
          <p>AGRILENE endeavours to ensure the accuracy of the information published on this website, but cannot guarantee completeness or timeliness. AGRILENE reserves the right to modify the content at any time without notice.</p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-ink mb-3" style="font-family: var(--font-display)">Personal data</h2>
          <p>
            For information about the processing of your personal data, please see our <a href="/en/politique-de-confidentialite" class="text-green hover:underline">Privacy policy</a>.
          </p>
        </div>

        <div class="text-xs text-muted/60 border-t border-ink/8 pt-4">
          Last updated: June 2026.
        </div>
      </div>
    </div>
  </section>

</Layout>

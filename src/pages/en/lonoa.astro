---
import Layout from '../../layouts/Layout.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import Button from '../../components/ui/Button.astro';
import ImagePlaceholder from '../../components/ui/ImagePlaceholder.astro';
import BandeauCTA from '../../components/sections/BandeauCTA.astro';
import Icon from '../../components/ui/Icon.astro';
import { appLinks } from '../../config/links';
import { dosageConfig, dosageModes } from '../../config/dosage';

const modeLabelsEn: Record<string, string> = {
  gazon: 'Lawn',
  rempotage: 'Potting',
  semis: 'Seeding',
  plantation: 'Planting',
};

const inputLabelsEn: Record<string, string> = {
  gazon: 'Lawn area (m²)',
  rempotage: 'Pot volume (L)',
  semis: 'Mix volume (L)',
  plantation: 'Pit volume (L)',
};

const calcConfig = dosageModes.map((key) => ({
  key,
  ...dosageConfig[key],
  labelEn: modeLabelsEn[key] ?? dosageConfig[key].label,
  inputLabelEn: inputLabelsEn[key] ?? dosageConfig[key].inputLabel,
}));

const steps = [
  { num: '1', title: 'You mix', text: 'Add LONOA to your potting mix when repotting or planting.' },
  { num: '2', title: 'It stores', text: 'LONOA acts like a mineral sponge — it absorbs water when you irrigate and holds it.' },
  { num: '3', title: 'Plants drink', text: 'Plants draw water as needed — you water less, and they last longer.' },
];

const benefits = [
  { text: 'Water stays available longer', icon: 'Droplet' as const },
  { text: 'Better root conditions', icon: 'Sprout' as const },
  { text: 'Less maintenance pressure', icon: 'CheckCircle' as const },
];

const range = [
  { name: 'LONOA Potting', use: 'Repotting & container growing', benefit: 'Regulates moisture at the root ball' },
  { name: 'LONOA Seeding', use: 'Seeding & young plants', benefit: 'Even germination, less stress' },
  { name: 'LONOA Lawn', use: 'Lawn & turfing', benefit: 'More resilient turf, less frequent watering' },
  { name: 'LONOA Planting', use: 'In-ground planting', benefit: 'Better establishment, fewer losses' },
];
---

<Layout
  title="LONOA — Plants that thrive, even when you forget to water"
  description="LONOA mixes into your potting soil to store water and release it to your plants when they need it. Less watering, stronger roots."
>

  <!-- HERO -->
  <section class="relative overflow-hidden bg-paper pt-16 pb-20 md:pt-24 md:pb-28">
    <div class="container relative">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 mb-4 px-3 py-1.5 rounded-full text-xs font-semibold text-white" style="background-color: var(--color-blue)">
            LONOA — By AGRILENE
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-ink mb-6 leading-tight" style="font-family: var(--font-display)">
            Plants that thrive, even when you forget to water
          </h1>
          <p class="text-lg text-muted mb-8 leading-relaxed max-w-xl">
            LONOA mixes into your potting soil to store water and release it to your plants at the right moment — less watering, stronger roots.
          </p>
          <div class="flex flex-wrap gap-3 mb-10">
            <a href="#range" class="inline-flex items-center gap-2 text-sm font-semibold px-6 py-3 rounded-full text-white transition-opacity hover:opacity-90" style="background-color: var(--color-blue)">
              See the range
            </a>
            <a href="#how-it-works" class="inline-flex items-center gap-2 text-sm font-semibold px-6 py-3 rounded-full border-2 text-ink transition-colors hover:bg-ink hover:text-white" style="border-color: var(--color-ink)">
              How it works
            </a>
          </div>
          <div class="flex flex-col sm:flex-row gap-4">
            {[
              { icon: 'Award' as const, label: 'Professional-grade minerals' },
              { icon: 'Calendar' as const, label: '40+ years of expertise' },
              { icon: 'Globe' as const, label: 'Proven in extreme conditions' },
            ].map((item) => (
              <div class="flex items-center gap-2 text-sm text-muted">
                <Icon name={item.icon} size={15} style="color: var(--color-blue)" />
                <span>{item.label}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="relative">
          <ImagePlaceholder ratio="4/3" alt="Cross-section pot with and without LONOA — vigorous roots and better water retention" label="Visual coming soon: pot cross-section without/with LONOA" />
          <div class="absolute bottom-4 left-4 bg-white/95 backdrop-blur-sm rounded-xl p-4 shadow-lg border border-blue/10 max-w-[190px]">
            <div class="flex items-center gap-2 mb-1">
              <Icon name="Droplet" size={15} style="color: var(--color-blue)" />
              <span class="text-xs font-bold" style="color: var(--color-blue); font-family: var(--font-display)">LONOA</span>
            </div>
            <p class="text-xs text-muted leading-tight">Smarter soil. Stronger roots. Less guesswork.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WITHOUT / WITH LONOA -->
  <section class="py-20 bg-cream">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <ImagePlaceholder ratio="3/2" alt="Comparison: stressed plant vs vigorous plant with LONOA" label="Comparative visual without/with LONOA" />
        </div>
        <div class="reveal">
          <Eyebrow color="blue" class="mb-4">The LONOA difference</Eyebrow>
          <h2 class="text-3xl font-bold text-ink mb-6" style="font-family: var(--font-display)">Without and with LONOA</h2>
          <div class="space-y-4">
            {benefits.map((b) => (
              <div class="flex gap-4 items-start">
                <div class="shrink-0" aria-hidden="true"><Icon name={b.icon} size={22} style="color: var(--color-blue)" /></div>
                <p class="text-ink font-medium">{b.text}</p>
              </div>
            ))}
          </div>
          <p class="mt-6 text-sm text-muted italic">LONOA is not a fertiliser: it is a <strong class="text-ink">mineral water regulator</strong> that improves root conditions.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class="py-20 bg-paper">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <Eyebrow color="blue" class="mb-3">Instructions</Eyebrow>
        <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4" style="font-family: var(--font-display)">How it works</h2>
        <p class="text-muted max-w-xl mx-auto">As simple as mixing.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {steps.map((e) => (
          <div class="text-center reveal card-lift bg-sage rounded-2xl p-8">
            <div class="w-12 h-12 rounded-full flex items-center justify-center text-lg font-bold text-white mx-auto mb-4" style="background-color: var(--color-blue)">{e.num}</div>
            <h3 class="font-bold text-ink mb-2" style="font-family: var(--font-display)">{e.title}</h3>
            <p class="text-sm text-muted">{e.text}</p>
          </div>
        ))}
      </div>
      <p class="text-center text-sm text-muted mt-8 italic">LONOA is not a fertiliser — it is a water regulator.</p>
    </div>
  </section>

  <!-- THE RANGE -->
  <section id="range" class="py-20 bg-cream">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <Eyebrow color="blue" class="mb-3">Range</Eyebrow>
        <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4" style="font-family: var(--font-display)">The LONOA range</h2>
        <p class="text-muted max-w-xl mx-auto">One product for every application.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {range.map((s) => (
          <article class="bg-paper rounded-2xl overflow-hidden card-lift reveal">
            <ImagePlaceholder ratio="1/1" alt={`${s.name} bag`} label="Pack visual coming soon" />
            <div class="p-5">
              <h3 class="font-bold text-ink mb-1" style="font-family: var(--font-display)">{s.name}</h3>
              <p class="text-xs text-muted mb-2">{s.use}</p>
              <p class="text-sm font-medium" style="color: var(--color-blue)">{s.benefit}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- MANA APP -->
  <section class="py-20 bg-paper">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <Eyebrow color="blue" class="mb-4">Mobile app</Eyebrow>
          <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4" style="font-family: var(--font-display)">Mana — the app that looks after your plants</h2>
          <p class="text-muted mb-6 leading-relaxed">
            Photograph your plant: <strong class="text-ink">Mana</strong> identifies it, runs a <strong class="text-ink">health check</strong> and suggests <strong class="text-ink">short-term solutions</strong> and <strong class="text-ink">care tips</strong> — including the right LONOA product if needed.
          </p>
          <div class="inline-flex items-center gap-3 bg-blue/5 border border-blue/20 rounded-xl px-5 py-4">
            <Icon name="FlaskConical" size={20} style="color: var(--color-blue)" />
            <p class="text-sm font-medium" style="color: var(--color-blue)">{appLinks.manaStatusEn}</p>
          </div>
        </div>
        <div class="reveal">
          <ImagePlaceholder ratio="3/4" alt="Mana app screenshots — plant diagnosis by photo" label="Mana screenshots coming soon" />
        </div>
      </div>
    </div>
  </section>

  <!-- DOSAGE CALCULATOR -->
  <section class="py-20 bg-sage">
    <div class="container max-w-2xl">
      <div class="text-center mb-8 reveal">
        <Eyebrow color="blue" class="mb-3">Dosage</Eyebrow>
        <h2 class="text-3xl font-bold text-ink mb-3" style="font-family: var(--font-display)">Dosage calculator</h2>
        <p class="text-muted">Estimate the amount of LONOA for your application.</p>
      </div>

      <div class="bg-paper rounded-2xl p-6 reveal" id="calc-lonoa">
        <div class="mb-5">
          <label class="block text-sm font-medium text-ink mb-2">Application</label>
          <div class="grid grid-cols-2 gap-2" role="radiogroup" aria-label="Dosage mode">
            {calcConfig.map((m, i) => (
              <label class="cursor-pointer">
                <input
                  type="radio"
                  name="calc-mode"
                  value={m.key}
                  class="sr-only"
                  checked={i === 0}
                  data-label={m.labelEn}
                  data-input-label={m.inputLabelEn}
                  data-unit={m.inputUnit}
                  data-default-pct={m.defaultPct}
                  data-depth-cm={m.depthCm ?? ''}
                  data-bag-volume={m.bagVolume}
                  data-show-bags={m.showBags ? '1' : '0'}
                  data-hint={m.hint ?? ''}
                  data-options={JSON.stringify(m.options)}
                />
                <span class="mode-btn block text-center text-xs font-semibold px-3 py-2.5 rounded-xl border-2 transition-all hover:border-blue/50" style="border-color: var(--color-ink); color: var(--color-ink);">
                  {m.labelEn}
                </span>
              </label>
            ))}
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-4 mb-5">
          <div>
            <label for="calc-input" id="calc-input-label" class="block text-sm font-medium text-ink mb-1.5">{calcConfig[0].inputLabelEn}</label>
            <div class="flex items-center gap-2">
              <input type="number" id="calc-input" min="0.1" max="10000" value="10" step="0.5"
                class="w-full border border-ink/20 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2"
                style="--tw-ring-color: var(--color-blue)" />
              <span id="calc-unit" class="text-sm text-muted shrink-0 min-w-[24px]">L</span>
            </div>
          </div>
          <div>
            <label for="calc-taux" class="block text-sm font-medium text-ink mb-1.5">Mix ratio</label>
            <select id="calc-taux" class="w-full border border-ink/20 rounded-xl px-4 py-2.5 text-sm bg-white focus:outline-none focus:ring-2" style="--tw-ring-color: var(--color-blue)">
              {calcConfig[0].options.map((o) => (
                <option value={o.pct} selected={o.pct === calcConfig[0].defaultPct}>{o.label}</option>
              ))}
            </select>
          </div>
        </div>

        <div class="bg-blue/10 rounded-xl p-5 text-center">
          <p class="text-sm text-muted mb-1">Recommended LONOA quantity</p>
          <p id="calc-result" class="text-3xl font-extrabold" style="font-family: var(--font-display); color: var(--color-blue)">2 L</p>
          <p id="calc-detail" class="text-xs text-muted mt-1"></p>
          <p id="calc-bags" class="text-xs text-muted mt-0.5 hidden"></p>
        </div>
        <p id="calc-hint" class="text-xs text-muted mt-3 italic hidden"></p>
      </div>
    </div>
  </section>

  <!-- WHERE TO FIND LONOA -->
  <section class="py-20 bg-paper">
    <div class="container text-center reveal">
      <Eyebrow color="blue" class="mb-4">Where to buy</Eyebrow>
      <h2 class="text-3xl font-bold text-ink mb-4" style="font-family: var(--font-display)">Where to find LONOA</h2>
      <p class="text-muted max-w-xl mx-auto">Coming soon online (Amazon and other platforms). Reseller network in development.</p>
    </div>
  </section>

  <!-- DISTRIBUTORS -->
  <section class="py-20 bg-cream">
    <div class="container">
      <div class="max-w-3xl mx-auto bg-paper rounded-2xl p-8 md:p-10 reveal">
        <Eyebrow color="orange" class="mb-4">For professionals</Eyebrow>
        <h2 class="text-2xl md:text-3xl font-bold text-ink mb-4" style="font-family: var(--font-display)">Are you a retailer or distributor?</h2>
        <p class="text-muted mb-6 leading-relaxed">LONOA is a differentiated product with strong consumer demand. We support our distributors with communication materials, the Mana app included, and dedicated technical support.</p>
        <ul class="space-y-2 mb-8 text-sm text-ink">
          {['Differentiated product on the market', 'Mana app included for your customers', 'Commercial and technical support', 'Sales training and materials provided'].map((item) => (
            <li class="flex gap-2"><span class="font-bold" style="color: var(--color-green)">✓</span>{item}</li>
          ))}
        </ul>
        <Button href="/en/contact?type=distribution" variant="primary" arrow>Become a distributor</Button>
      </div>
    </div>
  </section>

  <BandeauCTA titre="Questions about LONOA?" sousTitre="Our team is available to answer questions about products, dosage and stockists." ctaLabel="Contact us" ctaHref="/en/contact" ctaVariant="orange" bg="brown" />
</Layout>

<script>
  interface ModeOption { pct: number; label: string; }

  const calcInput = document.getElementById('calc-input') as HTMLInputElement | null;
  const calcTaux = document.getElementById('calc-taux') as HTMLSelectElement | null;
  const calcResult = document.getElementById('calc-result');
  const calcDetail = document.getElementById('calc-detail');
  const calcBags = document.getElementById('calc-bags');
  const calcHint = document.getElementById('calc-hint');
  const calcInputLabel = document.getElementById('calc-input-label');
  const calcUnit = document.getElementById('calc-unit');
  const modeBtns = document.querySelectorAll<HTMLElement>('.mode-btn');
  const modeRadios = document.querySelectorAll<HTMLInputElement>('input[name="calc-mode"]');

  function formatL(v: number): string {
    return v < 1 ? `${(v * 1000).toFixed(0)} mL` : `${v.toFixed(1).replace('.0', '')} L`;
  }

  function updateCalc() {
    const activeRadio = document.querySelector<HTMLInputElement>('input[name="calc-mode"]:checked');
    if (!activeRadio || !calcInput || !calcTaux || !calcResult) return;

    const inputVal = parseFloat(calcInput.value) || 0;
    const taux = parseFloat(calcTaux.value) || 20;
    const depthCm = parseFloat(activeRadio.dataset.depthCm || '0');
    const bagVolume = parseFloat(activeRadio.dataset.bagVolume || '80');
    const showBags = activeRadio.dataset.showBags === '1';
    const hint = activeRadio.dataset.hint || '';

    let volLonoa: number;
    let detailText: string;

    if (depthCm > 0) {
      const depthM = depthCm / 100;
      const totalVol = inputVal * depthM * 1000;
      volLonoa = Math.round((totalVol * (taux / 100)) * 10) / 10;
      detailText = `${taux}% × ${inputVal} m² × ${depthCm} cm depth`;
    } else {
      volLonoa = Math.round(inputVal * (taux / 100) * 10) / 10;
      detailText = `${taux}% of ${inputVal} ${activeRadio.dataset.unit} volume`;
    }

    calcResult.textContent = formatL(volLonoa);
    if (calcDetail) calcDetail.textContent = detailText;

    if (calcBags) {
      if (showBags && volLonoa > 0) {
        const bags = Math.ceil(volLonoa / bagVolume);
        calcBags.textContent = `≈ ${bags} bag${bags > 1 ? 's' : ''} of ${bagVolume} L`;
        calcBags.classList.remove('hidden');
      } else {
        calcBags.classList.add('hidden');
      }
    }

    if (calcHint) {
      if (hint) { calcHint.textContent = hint; calcHint.classList.remove('hidden'); }
      else { calcHint.classList.add('hidden'); }
    }
  }

  function activateMode(radio: HTMLInputElement) {
    if (calcInputLabel) calcInputLabel.textContent = radio.dataset.inputLabel ?? '';
    if (calcUnit) calcUnit.textContent = radio.dataset.unit ?? '';
    if (calcTaux) {
      try {
        const options: ModeOption[] = JSON.parse(radio.dataset.options || '[]');
        const defaultPct = parseInt(radio.dataset.defaultPct || '20');
        calcTaux.innerHTML = options.map((o) => `<option value="${o.pct}"${o.pct === defaultPct ? ' selected' : ''}>${o.label}</option>`).join('');
      } catch {}
    }
    modeBtns.forEach((btn) => { btn.style.borderColor = 'var(--color-ink)'; btn.style.color = 'var(--color-ink)'; btn.style.backgroundColor = ''; });
    const activeBtn = radio.nextElementSibling as HTMLElement | null;
    if (activeBtn) { activeBtn.style.borderColor = 'var(--color-blue)'; activeBtn.style.backgroundColor = 'var(--color-blue)'; activeBtn.style.color = 'white'; }
    updateCalc();
  }

  modeRadios.forEach((radio) => radio.addEventListener('change', () => activateMode(radio)));
  calcInput?.addEventListener('input', updateCalc);
  calcTaux?.addEventListener('change', updateCalc);
  const firstRadio = document.querySelector<HTMLInputElement>('input[name="calc-mode"]');
  if (firstRadio) activateMode(firstRadio);
</script>
